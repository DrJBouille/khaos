{
  "name": "worker-go",
  "root": "apps/worker/worker-go",
  "sourceRoot": "apps/worker-go",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go build -o dist/worker main.go",
        "cwd": "apps/worker/worker-go"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go run main.go",
        "cwd": "apps/worker/worker-go"
      }
    }
  }
}
